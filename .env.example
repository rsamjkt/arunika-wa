# WAHA instance this app proxies to
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=

# Seed admin account (only used the first time data/users.json is created)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional: seed an initial external API key (only used the first time
# data/apikeys.json is created). Leave blank to skip — new keys can always
# be generated later from Settings → API Key.
APP_API_KEY=

# Secret WAHA signs its webhook payloads with (HMAC-SHA512) — set this,
# then register the webhook against your WAHA session with the same key.
WAHA_WEBHOOK_SECRET=

# KlikQRIS (https://klikqris.com) — required for paid-plan registration.
KLIKQRIS_BASE_URL=https://klikqris.com/api
KLIKQRIS_API_KEY=
KLIKQRIS_MERCHANT_ID=

# Shared secret for the daily subscription-expiry cron endpoint
# (/api/cron/downgrade-expired) — not a login, just a bearer-style check.
CRON_SECRET=

# SMTP — welcome/payment-confirmation/password-reset/expiry-reminder
# emails, sent via your own mailbox (Gmail, Zoho, custom domain, etc).
# Leave SMTP_HOST blank to no-op (logged, not thrown) while developing.
# For Gmail: smtp.gmail.com, port 587, SMTP_SECURE=false, and SMTP_PASS
# must be a 16-character App Password (myaccount.google.com/apppasswords)
# — your normal Gmail password will not work.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
